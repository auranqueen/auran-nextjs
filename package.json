    "scrape:civasan": "ts-node --project tsconfig.scripts.json scripts/scrape-civasan.ts",
    "scrape:soskin": "ts-node --project tsconfig.scripts.json scripts/scrape-soskin.ts",
    "scrape:thalac": "ts-node --project tsconfig.scripts.json scripts/scrape-thalac.ts",
    "scrape:all": "npm run scrape:gernetic && npm run scrape:civasan && npm run scrape:soskin && npm run scrape:thalac"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
