# AURAN Platform — 환경변수 설정
# .env.example → .env.local 로 복사 후 실제 값 입력

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# 서비스 롤 키 (PIN 저장·승인·관리자 등 RLS 우회용) — Supabase 대시보드 → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── App ──
NEXT_PUBLIC_APP_URL=https://auran.kr

# ── 토스페이먼츠 ──
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
TOSS_SECRET_KEY=test_sk_D4yKeq5bgrpKX9E041BgLzN97Eoq

# ── 카카오 알림톡 (뿌리오 / 비즈뿌리오) ──
# PPURIO_API_KEY·PPURIO_SENDER_KEY 미설정 시 발송은 건너뛰고 서버 로그만 출력됩니다.
# PPURIO_API_KEY: "비즈뿌리오계정:API비밀번호" 또는 PPURIO_ACCOUNT + PPURIO_API_KEY(비밀번호만)
PPURIO_API_KEY=
# 카카오 채널 발신 프로필 키 (senderkey)
PPURIO_SENDER_KEY=
# 비즈뿌리오에 등록한 발신 번호 (실발송 시 필수)
PPURIO_FROM=
# 검수: https://dev-api.bizppurio.com
# PPURIO_API_BASE=https://api.bizppurio.com
# 템플릿 코드 (승인 후)
# PPURIO_TEMPLATE_SIGNUP=
# PPURIO_TEMPLATE_COUPON=
# PPURIO_TEMPLATE_TEST=
# PPURIO_TEMPLATE_DEFAULT=

# ── PayApp (결제) ──
# 개발/테스트 시 실결제 방지: PAYAPP_SANDBOX=true 또는 PAYAPP_TEST_MODE=true
# 설정 시 결제 요청이 페이앱 서버로 가지 않고, 바로 return URL로 이동합니다.
# PAYAPP_LINKVAL 등은 샌드박스일 때는 불필요합니다.
# PAYAPP_SANDBOX=true
# PAYAPP_TEST_MODE=true

# 실결제용 (샌드박스가 아닐 때 필수)
# PAYAPP_USER_ID=
# PAYAPP_SHOPNAME=
# PAYAPP_LINKKEY=
# PAYAPP_LINKVAL=
# PAYAPP_FEEDBACK_URL=https://your-domain/api/payments/payapp/webhook
# PAYAPP_RETURN_URL=  # 비워두면 자동으로 /api/payments/payapp/return

# ── 앱 설정 ──
NEXT_PUBLIC_PLATFORM_NAME=AURAN
NEXT_PUBLIC_PLATFORM_FEE_RATE=9.5
